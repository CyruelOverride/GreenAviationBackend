# Copia a .env. No subir .env al repo.
# Si usas Supabase en una red solo IPv4 (ej. Render): usa la URI del Session Pooler
# (Supabase → Project Settings → Database → Connection pooling → Session), puerto 6543.

DATABASE_URL=postgresql://postgres:****@db.xxx.supabase.co:5432/postgres
JWT_SECRET=tu-clave-secreta-larga-y-aleatoria

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Opcionales: NODE_ENV, PORT, JWT_EXPIRE, DEBUG_QUERIES
